{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "types": ["vite/client", "vitest/globals"],
    "noEmit": true,
    "isolatedModules": true,
  },
}
